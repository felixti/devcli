{
  "name": "devcli",
  "version": "0.1.0",
  "type": "module",
  "bin": {
    "devcli": "bin/devcli.ts"
  },
  "files": [
    "bin",
    "src/**/*.ts",
    "!src/**/*.test.ts",
    "package.json"
  ],
  "engines": {
    "node": ">=18"
  },
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@types/bun": "latest",
    "@types/node": "^20",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5"
  },
  "dependencies": {
    "@commander-js/extra-typings": "^12",
    "commander": "^12",
    "zod": "^3"
  },
  "scripts": {
    "prepare": "husky",
    "lint": "biome check src/",
    "lint:fix": "biome check --fix src/",
    "format": "biome format src/",
    "format:fix": "biome format --fix src/",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run typecheck && bun run lint && bun test"
  },
  "lint-staged": {
    "*.ts": ["biome check --fix --no-errors-on-unmatched"]
  }
}
